<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="mask"
                    converterClass="com.github.lamarios.newsku.logging.SensitiveMaskingConverter"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %mask%n</pattern>
        </encoder>
    </appender>

    <!-- Dedicated security-audit appender — routed to CONSOLE here;
         in production, point to a separate file or SIEM sink. -->
    <logger name="security-audit" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Tomcat loggt bei jedem Keep-Alive-Close des Clients eine EOFException
         auf DEBUG. Das ist normales Verhalten (Browser schließt Socket nach
         Request), verrauscht aber jedes Log. Auf INFO heben statt komplett
         stumm, damit echte HTTP-Parser-Fehler sichtbar bleiben. -->
    <logger name="org.apache.coyote.http11.Http11Processor" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <springProfile name="!prod">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
