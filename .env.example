# ============================================================
# Newsku – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und trage die Werte ein.
# NIEMALS .env committen – nur .env.example versionieren!
# ============================================================

# ---- Datenbank ----
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=newsku
DB_USER=newsku
DB_PASSWORD=CHANGE_ME

# ---- PostgreSQL (fuer docker-compose) ----
POSTGRES_DB=newsku
POSTGRES_USER=newsku
POSTGRES_PASSWORD=CHANGE_ME

# ---- Frontend / CORS ----
# Oeffentliche URL der Anwendung – MUSS der URL entsprechen, unter der die App erreichbar ist.
# Wird als CORS-Fallback-Origin und fuer Links in E-Mails verwendet.
# Beispiele: https://news.example.com  |  http://192.168.1.10:8080
# WICHTIG: Falsche ROOT_URL fuehrt zu CORS-403-Fehlern im Web-Frontend.
ROOT_URL=http://localhost:8080
# Erlaubte Frontend-Origins fuer CORS (kommagetrennt), falls das Frontend separat gehostet wird.
# Beispiel: https://app.example.com,https://www.example.com
# Wenn leer, wird ROOT_URL als einzige erlaubte Origin verwendet.
FRONTEND_URL=

# ---- OpenAI / LLM ----
# API-Key fuer OpenAI (https://platform.openai.com/api-keys).
# Bei Ollama / selbst gehosteten Endpunkten nicht erforderlich – leer lassen.
OPENAI_API_KEY=sk-CHANGE_ME
# Modellname, z. B. gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Fuer Ollama z. B.: llama3.2, qwen2.5, mistral-small usw.
OPENAI_MODEL=gpt-4o
# API-Endpunkt. Standard: https://api.openai.com/v1
# Ollama-Beispiel: http://ollama.example.com/v1
#   → kein API-Key noetig; einfach OPENAI_API_KEY leer lassen.
# Wenn nur OPENAI_URL gesetzt ist (kein Key), wird "ollama" als
# Platzhalter im Authorization-Header verwendet (wird vom Server ignoriert).
OPENAI_URL=
# Maximale Anzahl an Wiederholungsversuchen bei LLM-Fehlern (Standard: 3)
OPENAI_MAX_RETRIES=3
# Timeout fuer LLM-Anfragen in Minuten (Standard: 2)
OPENAI_TIMEOUT_MINUTES=2

# ---- Image-Cache ----
# Verzeichnis fuer den Image-Cache im Container (Standard: /app/cache/images).
# Nur setzen, wenn ein abweichender Pfad gemountet werden soll. Leer lassen oder
# weglassen – niemals auf "/" oder einen Systempfad setzen.
# IMAGE_CACHE_DIR=/app/cache/images
# Maximale Cache-Groesse in MB (Standard: 500)
IMAGE_CACHE_MAX_SIZE_MB=500
# Maximales Alter gecachter Bilder in Tagen (Standard: 7)
IMAGE_CACHE_MAX_AGE_DAYS=7

# ---- Login Rate Limiting ----
# Maximale Login-Versuche pro IP innerhalb des Zeitfensters (Standard: 10)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
# Zeitfenster fuer Rate Limiting in Millisekunden (Standard: 60000 = 1 Minute)
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# ---- Sicherheit ----
# Zufaelliger Salt fuer Passwort-Hashing (min. 32 Zeichen, nie aendern!)
SALT=CHANGE_ME_USE_RANDOM_STRING_MIN_32_CHARS
# AES-Schluessel fuer die Verschluesselung sensibler Felder at rest
# (GReader-Passwort, per-User OpenAI API-Key). Pflicht; Startup bricht sonst ab.
# NIE aendern nach Inbetriebnahme, sonst koennen bestehende Ciphertexte nicht
# mehr entschluesselt werden.
#
# Schluessel generieren (32 Byte Base64) – diesen Befehl im Terminal ausfuehren
# und den Output unten einsetzen:
#
#     openssl rand -base64 32
#
APP_ENCRYPTION_KEY=CHANGE_ME_RUN_openssl_rand_base64_32

# ---- GReader-Integration ----
# Basis-URL der GReader-kompatiblen Instanz (z. B. https://freshrss.example.com, https://miniflux.example.com)
# Leer lassen, um die Integration zu deaktivieren.
GREADER_URL=

# ---- SMTP (E-Mail-Versand) ----
# Wenn leer, ist der E-Mail-Versand deaktiviert.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Transportstrategie: SMTP, SMTPS oder SMTP_TLS (Standard: SMTP)
SMTP_TRANSPORT_STRATEGY=SMTP_TLS

# ---- Benutzerregistrierung ----
# 0 = Registrierung deaktiviert (Standard)
# 1 = Registrierung fuer neue Benutzer erlaubt
ALLOW_SIGNUP=0

# ---- Feed-Sync ----
# Spring-Cron-Expression (6 Felder: sec min hour day month weekday).
# Default 0 15,35,55 * * * *  => 3x/Stunde zu Minute :15, :35, :55.
# Abgestimmt auf FreshRSS-Standard CRON_MIN=10,30,50: newsku synct
# jeweils 5 Min nach jedem FreshRSS-Fetch.
#FEED_SYNC_CRON=0 15,35,55 * * * *

# ---- Zeitzone ----
TZ=Europe/Berlin
