# ============================================================
# Newsku – Umgebungsvariablen Vorlage
# Kopiere diese Datei nach .env und trage die Werte ein.
# NIEMALS .env committen – nur .env.example versionieren!
# ============================================================

# ---- Datenbank ----
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=newsku
DB_USER=newsku
DB_PASSWORD=CHANGE_ME

# ---- PostgreSQL (fuer docker-compose) ----
POSTGRES_DB=newsku
POSTGRES_USER=newsku
POSTGRES_PASSWORD=CHANGE_ME

# ---- Frontend / CORS ----
# Basis-URL der Anwendung (wird fuer Links in E-Mails und als CORS-Fallback verwendet)
ROOT_URL=http://localhost:8080
# Erlaubte Frontend-Origins fuer CORS (kommagetrennt, z. B. https://app.example.com,https://www.example.com)
# Wenn leer, wird ROOT_URL als einzige erlaubte Origin verwendet.
FRONTEND_URL=

# ---- OpenAI / LLM ----
# API-Key von https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME
# Modellname, z. B. gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o
# Optional: eigener API-Endpunkt (z. B. lokales Ollama oder kompatible API)
# Standard: https://api.openai.com/v1
OPENAI_URL=
# Maximale Anzahl an Wiederholungsversuchen bei OpenAI-Fehlern (Standard: 3)
OPENAI_MAX_RETRIES=3
# Timeout fuer OpenAI-Anfragen in Minuten (Standard: 2)
OPENAI_TIMEOUT_MINUTES=2

# ---- Image-Cache ----
# Verzeichnis fuer den Image-Cache (Standard: Systemtempverzeichnis/newsku-images)
IMAGE_CACHE_DIR=
# Maximale Cache-Groesse in MB (Standard: 500)
IMAGE_CACHE_MAX_SIZE_MB=500
# Maximales Alter gecachter Bilder in Tagen (Standard: 7)
IMAGE_CACHE_MAX_AGE_DAYS=7

# ---- Login Rate Limiting ----
# Maximale Login-Versuche pro IP innerhalb des Zeitfensters (Standard: 10)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
# Zeitfenster fuer Rate Limiting in Millisekunden (Standard: 60000 = 1 Minute)
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# ---- Sicherheit ----
# Zufaelliger Salt fuer Passwort-Hashing (min. 32 Zeichen, nie aendern!)
SALT=CHANGE_ME_USE_RANDOM_STRING_MIN_32_CHARS

# ---- FreshRSS-Integration ----
# Basis-URL der FreshRSS-Instanz (z. B. https://freshrss.example.com)
# Leer lassen, um die Integration zu deaktivieren.
FRESHRSS_URL=

# ---- SMTP (E-Mail-Versand) ----
# Wenn leer, ist der E-Mail-Versand deaktiviert.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Transportstrategie: SMTP, SMTPS oder SMTP_TLS (Standard: SMTP)
SMTP_TRANSPORT_STRATEGY=SMTP_TLS

# ---- Benutzerregistrierung ----
# 0 = Registrierung deaktiviert (Standard)
# 1 = Registrierung fuer neue Benutzer erlaubt
ALLOW_SIGNUP=0

# ---- Zeitzone ----
TZ=Europe/Berlin
